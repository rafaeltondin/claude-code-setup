{
  "version": "1.0.0",
  "logging": {
    "level": "INFO",
    "showTimestamps": true,
    "showAgentNames": true,
    "colorOutput": true,
    "logToFile": false,
    "logFilePath": "./.logs/claude-agents.log"
  },
  "agents": {
    "preferredLanguages": ["python", "javascript", "typescript"],
    "customAgents": [],
    "disabledAgents": [],
    "defaultModel": "sonnet",
    "allowParallelExecution": true
  },
  "orchestrator": {
    "maxParallelAgents": 3,
    "timeoutMinutes": 30,
    "autoSave": true,
    "confirmBeforeExecution": false,
    "verboseMode": false
  },
  "ui": {
    "progressBar": true,
    "showSpinner": true,
    "notifications": true,
    "soundAlerts": false,
    "theme": "default"
  },
  "history": {
    "enabled": true,
    "maxEntries": 100,
    "autoCleanupDays": 30,
    "trackFileChanges": true
  },
  "performance": {
    "enableCaching": true,
    "cacheDirectory": "./.cache",
    "cacheTTL": 3600,
    "enableMetrics": true
  },
  "security": {
    "validateInputs": true,
    "sanitizeOutputs": true,
    "allowScriptExecution": true,
    "restrictedPaths": []
  },
  "integrations": {
    "git": {
      "autoCommit": false,
      "commitMessageTemplate": "feat: {description}\n\nGenerated by Claude Code"
    },
    "editor": {
      "default": "vscode",
      "autoOpen": false
    }
  }
}
