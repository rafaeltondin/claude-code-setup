{
  "mcpServers": {
    "chrome-devtools": {
      "command": "node",
      "args": [
        "$HOME/.claude/src/integrations/chrome/chrome-mcp-launcher.js"
      ]
    },
    "desktop-commander": {
      "command": "npx",
      "args": [
        "@wonderwhy-er/desktop-commander"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chrome",
        "--headless",
        "false",
        "--viewport-size",
        "1920x1080",
        "--user-data-dir",
        "./.claude/playwright-profile"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "claude-ecosystem": {
      "command": "node",
      "args": [
        "$HOME/.claude/mcp-server/index.js"
      ]
    },
    "codebase-memory": {
      "command": "codebase-memory-mcp",
      "args": []
    }
  }
}
