{
  "name": "frontend-analyzer",
  "version": "2.1.0",
  "description": "Ferramenta completa de análise frontend com dashboard Chrome DevTools e seleção de perfil Google",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dashboard": "node src/index.js --dashboard",
    "dashboard:port": "node src/index.js --dashboard --port",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "frontend",
    "analyzer",
    "css",
    "html",
    "lint",
    "accessibility",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chrome-launcher": "^1.2.1",
    "css-tree": "^2.3.1",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "htmlparser2": "^9.1.0",
    "inquirer": "^9.2.12",
    "parse5": "^7.1.2",
    "postcss": "^8.4.32",
    "postcss-selector-parser": "^6.0.15",
    "puppeteer-core": "^24.37.3",
    "specificity": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
